@page
@model RegisterModel
@{
    ViewData["Title"] = "Înregistrare AngelAirlines";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white text-center py-4">
                <h2 class="mb-0"><i class="fa-solid fa-user-plus"></i></h2>
                <h4 class="fw-bold">Creează Cont Nou</h4>
                <p class="small mb-0">Alătură-te flotei AngelAirlines</p>
            </div>
            <div class="card-body p-4">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserName" class="form-control" placeholder="Alege un nume de utilizator" />
                        <label asp-for="Input.UserName"><i class="fa-solid fa-at me-2"></i>Nume Utilizator</label>
                        <span asp-validation-for="Input.UserName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Adresă Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="password" />
                                <label asp-for="Input.Password">Parolă</label>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="password" />
                                <label asp-for="Input.ConfirmPassword">Confirmă Parola</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mt-3">
                        <button id="registerSubmit" type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                            Finalizează Înregistrarea
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <p class="mb-0 small">Ai deja un cont? <a asp-page="./Login" class="text-success fw-bold">Autentifică-te</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}