@page
@model IndexModel
@{
    ViewData["Title"] = "Profil AngelAirlines";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fa-solid fa-address-card"></i> Informații Profil</h5>
    </div>
    <div class="card-body p-4">
        <partial name="_StatusMessage" for="StatusMessage" />
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.UserName" class="form-control" placeholder="Numele tău" />
                <label asp-for="Input.UserName">Nume Utilizator</label>
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Telefon" />
                <label asp-for="Input.PhoneNumber">Număr de Telefon</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">
                Salvează Modificările
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}