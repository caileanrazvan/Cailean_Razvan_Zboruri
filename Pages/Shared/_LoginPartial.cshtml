@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            <a class="nav-link text-white fw-bold" asp-area="Identity" asp-page="/Account/Manage/Index">
                <i class="fa-solid fa-circle-user me-1"></i> Salut, @User.Identity?.Name!
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Deconectare
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="btn btn-sm btn-outline-light" asp-area="Identity" asp-page="/Account/Register">
                <i class="fa-solid fa-user-plus"></i> Înregistrare
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-sm btn-light fw-bold text-primary shadow-sm" asp-area="Identity" asp-page="/Account/Login">
                <i class="fa-solid fa-right-to-bracket"></i> Autentificare
            </a>
        </li>
    }
</ul>