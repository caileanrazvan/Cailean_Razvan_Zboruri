@page
@model Cailean_Razvan_Zboruri.Pages.Booking.CreateModel
@{
    ViewData["Title"] = "Finalizare Rezervare";
    // Calculăm prețul de bază pentru a-l afișa în sumar
    var baseTotal = Model.SelectedFlight.BasePrice * Model.PassengersCount;
}

<div class="container mt-4 mb-5">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="/Flight/Index" class="btn btn-outline-secondary rounded-circle me-3"><i class="fa-solid fa-arrow-left"></i></a>
        <h2 class="fw-bold mb-0 text-primary">Finalizare Rezervare</h2>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Booking.FlightID" value="@Model.SelectedFlight.ID" />
        <input type="hidden" name="PassengersCount" value="@Model.PassengersCount" />

        <div class="row g-4">
            <div class="col-lg-8">

                <div class="passengers-container mb-4">
                    @for (int i = 0; i < Model.PassengersCount; i++)
                    {
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-body p-4">

                                <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">
                                    <i class="fa-solid fa-user me-2"></i>Pasager @(i + 1) @(i == 0 ? "(Contact Principal)" : "")
                                </h5>

                                <div class="row g-3 mb-4">
                                    <input type="hidden" name="PassengerInputs[@i].SeatNumber" class="passenger-seat-input" data-passenger-index="@i" />
                                    <div class="col-md-2">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Titlu</label>
                                        <select name="PassengerInputs[@i].Title" class="form-select border-primary-subtle" required>
                                            <option value="">Alege...</option>
                                            <option value="Mr.">Mr. (Dl.)</option>
                                            <option value="Mrs.">Mrs. (Dna.)</option>
                                            <option value="Ms.">Ms. (Dra.)</option>
                                            <option value="Child">Copil</option>
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Nume (Familie)</label>
                                        <input name="PassengerInputs[@i].LastName" class="form-control border-primary-subtle" placeholder="Ex: Popescu" required />
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Prenume</label>
                                        <input name="PassengerInputs[@i].FirstName" class="form-control border-primary-subtle" placeholder="Ex: Ion" required />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-muted small fw-bold text-uppercase">Data Nașterii</label>
                                        <input type="date" name="PassengerInputs[@i].DateOfBirth" class="form-control border-primary-subtle" max="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                    </div>

                                    @if (i == 0)
                                    {
                                        <div class="col-md-4">
                                            <label class="form-label text-muted small fw-bold text-uppercase">Email Contact</label>
                                            <input type="email" name="ContactEmail" class="form-control border-primary-subtle" placeholder="adresa@email.com" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label text-muted small fw-bold text-uppercase">Telefon Contact</label>
                                            <input type="tel" name="ContactPhone" class="form-control border-primary-subtle" placeholder="+40 7..." required />
                                        </div>
                                    }
                                </div>

                                <div class="bg-light p-3 rounded-4 border border-primary-subtle">
                                    <h6 class="fw-bold mb-3"><i class="fa-solid fa-plus-circle text-primary me-2"></i>Opțiuni Extra pentru Pasagerul @(i + 1)</h6>
                                    <div class="alert alert-primary bg-primary-subtle border-0 d-flex align-items-center p-3 mb-3 rounded-3">
                                        <i class="fa-solid fa-suitcase-rolling fs-3 text-primary me-3"></i>
                                        <div>
                                            <strong class="d-block text-dark">Bagaj gratuit inclus</strong>
                                            <span class="small text-muted">Fiecare pasager beneficiază de 1 bagaj de cabină (troller) și 1 articol personal (rucsac/geantă).</span>
                                        </div>
                                    </div>
                                    <div class="row g-2">
                                        @foreach (var amenity in Model.AvailableAmenities)
                                        {
                                            <div class="col-md-6">
                                                <label class="w-100 h-100 amenity-checkbox-container m-0">
                                                    <input type="checkbox" name="PassengerInputs[@i].SelectedAmenitiesIds" value="@amenity.ID" class="d-none amenity-checkbox" data-price="@amenity.Price" onchange="calculateTotal()" />

                                                    <div class="card border border-2 rounded-3 h-100 amenity-card-visual transition cursor-pointer bg-white">
                                                        <div class="row g-0 align-items-center h-100">
                                                            <div class="col-3 h-100">
                                                                <img src="@(string.IsNullOrEmpty(amenity.ImageUrl) ? "/images/default-service.jpg" : amenity.ImageUrl)" class="img-fluid rounded-start-3 h-100" style="object-fit: cover; min-height: 70px;" alt="">
                                                            </div>
                                                            <div class="col-9">
                                                                <div class="card-body p-2">
                                                                    <div class="d-flex justify-content-between align-items-center">
                                                                        <span class="fw-bold text-primary small">@amenity.Name</span>
                                                                        <span class="badge bg-success-subtle text-success rounded-pill">+@amenity.Price €</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>

            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow rounded-4 position-sticky" style="top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Sumar Rezervare</h5>

                        <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                            <div class="text-center">
                                <h4 class="fw-bold text-primary mb-0">@Model.SelectedFlight.DepartureAirport.IataCode</h4>
                                <small class="text-muted">@Model.SelectedFlight.DepartureTime.ToString("HH:mm")</small>
                            </div>
                            <div class="text-center px-2">
                                <i class="fa-solid fa-plane text-muted"></i>
                                <div class="small text-muted mt-1" style="font-size: 0.7rem;">@Model.SelectedFlight.DepartureTime.ToString("dd MMM yyyy")</div>
                            </div>
                            <div class="text-center">
                                <h4 class="fw-bold text-primary mb-0">@Model.SelectedFlight.ArrivalAirport.IataCode</h4>
                                <small class="text-muted">@Model.SelectedFlight.ArrivalTime.ToString("HH:mm")</small>
                            </div>
                        </div>

                        <div class="mb-2 d-flex justify-content-between text-muted">
                            <span>Bilet Zbor</span>
                            <span class="fw-semibold">@baseTotal €</span>
                        </div>
                        <div class="mb-3 d-flex justify-content-between text-muted">
                            <span>Servicii Extra</span>
                            <span class="fw-semibold text-success" id="extrasTotal">0 €</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <span class="fs-5 fw-bold text-dark">Total</span>
                            <span class="fs-3 fw-bolder text-primary" id="grandTotal" data-base="@baseTotal">@baseTotal €</span>
                        </div>

                        <div class="card border-0 shadow-sm rounded-4 mb-4 mt-4">
                            <div class="card-body p-4 text-center">
                                <h4 class="fw-bold mb-3"><i class="fa-solid fa-chair text-primary me-2"></i>Alege Locurile</h4>
                                <p class="text-muted small">Selectează <strong id="seatsNeeded">@Model.PassengersCount</strong> locuri.</p>

                                <div class="d-flex justify-content-center gap-4 mb-4 small fw-bold">
                                    <div><div class="seat-legend available border"></div> Disponibil</div>
                                    <div><div class="seat-legend selected bg-primary"></div> Selectat</div>
                                    <div><div class="seat-legend occupied bg-secondary text-white border-0"><i class="fa-solid fa-xmark" style="font-size:10px;"></i></div> Ocupat</div>
                                </div>

                                <div class="plane-fuselage mx-auto p-4 rounded-5" style="max-width: 400px; background-color: #f8f9fa; border: 2px solid #e9ecef;">
                                    <div id="seatMap" class="d-flex flex-column gap-2"></div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold mt-4 shadow-sm text-uppercase rounded-pill">
                            <i class="fa-solid fa-lock me-2"></i> Plătește și Rezervă
                        </button>
                        <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.75rem;">Făcând click pe buton, ești de acord cu Termenii și Condițiile AngelAirlines.</p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    /* Cand inputul hidden este checked, schimbam borderul cardului vizual */
    .amenity-checkbox:checked + .amenity-card-visual {
        border-color: #0052D4 !important;
        background-color: rgba(0, 82, 212, 0.05);
        box-shadow: 0 0 0 3px rgba(0, 82, 212, 0.2);
    }

    .seat {
        width: 40px;
        height: 40px;
        border: 2px solid #0052D4;
        border-radius: 8px 8px 4px 4px; /* Forma de scaun */
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: bold;
        color: #0052D4;
        transition: all 0.2s;
        background-color: white;
    }

        .seat:hover:not(.occupied) {
            background-color: #e0ebff;
            transform: translateY(-2px);
        }

        .seat.selected {
            background-color: #0052D4;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 82, 212, 0.3);
        }

        .seat.occupied {
            background-color: #cbd5e1;
            border-color: #cbd5e1;
            color: white;
            cursor: not-allowed;
        }

    .aisle-number {
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #94a3b8;
    }

    .seat-legend {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        vertical-align: middle;
        margin-right: 5px;
    }
</style>

<script>
    // Script simplu pentru a actualiza pretul total in timp real cand bifezi servicii
    function calculateTotal() {
        let basePrice = parseFloat(document.getElementById('grandTotal').getAttribute('data-base'));
        let extrasTotal = 0;

        // Cautam toate checkboxurile bifate
        let checkboxes = document.querySelectorAll('.amenity-checkbox:checked');
        checkboxes.forEach(function(cb) {
            extrasTotal += parseFloat(cb.getAttribute('data-price'));
        });

        // Actualizam textele de pe ecran
        document.getElementById('extrasTotal').innerText = extrasTotal + ' €';
        document.getElementById('grandTotal').innerText = (basePrice + extrasTotal) + ' €';
    }

        // Preluăm datele din C# în JavaScript
    const occupiedSeats = @Html.Raw(Json.Serialize(Model.OccupiedSeats));
    const maxPassengers = @Model.PassengersCount;
    let selectedSeats = [];

    const rows = 30;
    const cols = ['A', 'B', 'C', 'D', 'E'];
    const seatMapContainer = document.getElementById('seatMap');

    // Generăm Harta
    for (let i = 1; i <= rows; i++) {
        const rowDiv = document.createElement('div');
        rowDiv.className = 'd-flex justify-content-center gap-2';

        cols.forEach((col, index) => {
            const seatId = `${i}${col}`; // Ex: 12B
            const isOccupied = occupiedSeats.includes(seatId);

            // Creăm scaunul
            const seat = document.createElement('div');
            seat.className = `seat ${isOccupied ? 'occupied' : ''}`;
            seat.innerText = isOccupied ? 'X' : col;
            seat.dataset.seat = seatId;

            // Adăugăm Culoarul după coloana B (index 1)
            if (index === 2) {
                const aisle = document.createElement('div');
                aisle.className = 'aisle-number';
                aisle.innerText = i; // Afișăm numărul rândului pe culoar
                rowDiv.appendChild(aisle);
            }

            // Click Event pentru selecție
            if (!isOccupied) {
                seat.addEventListener('click', function() {
                    toggleSeat(this, seatId);
                });
            }

            rowDiv.appendChild(seat);
        });

        seatMapContainer.appendChild(rowDiv);
    }

    function toggleSeat(seatElement, seatId) {
        const index = selectedSeats.indexOf(seatId);

        if (index > -1) {
            // Deselectare
            selectedSeats.splice(index, 1);
            seatElement.classList.remove('selected');
        } else {
            // Selectare
            if (selectedSeats.length < maxPassengers) {
                selectedSeats.push(seatId);
                seatElement.classList.add('selected');
            } else {
                alert(`Poți selecta maxim ${maxPassengers} locuri! Deselectează un loc curent pentru a alege altul.`);
            }
        }
        updateHiddenInputs();
    }

        function updateHiddenInputs() {
        // 1. Curățăm toate input-urile de locuri (în caz că utilizatorul s-a răzgândit)
        document.querySelectorAll('.passenger-seat-input').forEach(input => input.value = '');

        // 2. Punem locurile selectate fix în căsuțele fiecărui pasager
        selectedSeats.forEach((seat, index) => {
            const input = document.querySelector(`.passenger-seat-input[data-passenger-index="${index}"]`);
            if (input) {
                input.value = seat;
            }
        });
    }

        // Validare la apăsarea butonului de Rezervare
    document.querySelector('form').addEventListener('submit', function(e) {
        if (selectedSeats.length < maxPassengers) {
            e.preventDefault(); // Oprește trimiterea către plată
            alert(`Atenție! Trebuie să selectezi ${maxPassengers} locuri pe harta avionului înainte de a continua.`);

            // Face un scroll automat către harta avionului
            document.getElementById('seatMap').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>