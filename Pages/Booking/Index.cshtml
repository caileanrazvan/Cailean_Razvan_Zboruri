@page
@model Cailean_Razvan_Zboruri.Pages.Bookings.IndexModel
@{
    ViewData["Title"] = "Rezervările Mele";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-suitcase-rolling text-primary me-2"></i>
            @(User.IsInRole("Admin") ? "Toate Rezervările (Mod Admin)" : "Rezervările Mele")
        </h2>
    </div>

    @if (!Model.Booking.Any())
    {
        <div class="alert bg-light border border-primary-subtle rounded-4 p-5 text-center shadow-sm">
            <i class="fa-solid fa-ticket-simple display-1 text-muted mb-3 opacity-50"></i>
            <h4 class="fw-bold">Nu ai nicio rezervare înregistrată.</h4>
            <p class="text-muted">Când vei rezerva un zbor, detaliile acestuia vor apărea aici.</p>
            <a asp-page="/Index" class="btn btn-warning mt-3 fw-bold rounded-pill px-4">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Caută Zboruri
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Booking)
            {
                // Verificăm dacă zborul a plecat deja
                bool isPast = item.Flight.DepartureTime < DateTime.Now;

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 position-relative transition-hover @(isPast ? "bg-light opacity-75 border-secondary" : "")">

                        @if (isPast)
                        {
                            <div class="position-absolute top-0 start-50 translate-middle-x badge bg-secondary shadow-sm" style="margin-top: -10px; z-index: 5;">
                                <i class="fa-solid fa-clock-rotate-left me-1"></i> ISTORIC
                            </div>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="bg-dark text-white text-center py-2 px-3" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                                <small class="fw-bold"><i class="fa-solid fa-user-shield text-warning me-1"></i> E-mail Client:</small>
                                <div class="small font-monospace text-warning">@item.ContactEmail</div>
                            </div>
                        }

                        <div class="card-header @(User.IsInRole("Admin") ? "bg-transparent border-bottom-0 pt-3 pb-0" : "bg-transparent border-bottom-0 pt-4 pb-0")">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1">
                                    Zbor #@item.Flight?.FlightNumber
                                </span>
                                <span class="text-muted small fw-bold">Rezervat: @item.BookingDate.ToString("dd MMM yyyy")</span>
                            </div>

                            <div class="bg-white border rounded-3 p-3 mb-2 shadow-sm">
                                <div class="d-flex justify-content-between align-items-center text-center">
                                    <div class="w-50 border-end">
                                        <h4 class="fw-bold text-dark mb-0">@item.Flight?.DepartureAirport?.IataCode</h4>
                                        <div class="text-muted small">@item.Flight?.DepartureTime.ToString("HH:mm")</div>
                                        <div class="text-muted small text-truncate px-1" style="font-size: 0.65rem;" title="@item.Flight?.DepartureAirport?.Name">@item.Flight?.DepartureAirport?.Name</div>
                                    </div>
                                    <div class="px-2">
                                        <i class="fa-solid fa-plane text-primary opacity-50"></i>
                                    </div>
                                    <div class="w-50 border-start">
                                        <h4 class="fw-bold text-dark mb-0">@item.Flight?.ArrivalAirport?.IataCode</h4>
                                        <div class="text-muted small">@item.Flight?.ArrivalTime.ToString("HH:mm")</div>
                                        <div class="text-muted small text-truncate px-1" style="font-size: 0.65rem;" title="@item.Flight?.ArrivalAirport?.Name">@item.Flight?.ArrivalAirport?.Name</div>
                                    </div>
                                </div>
                                <div class="text-center mt-2 pt-2 border-top text-muted" style="font-size: 0.75rem;">
                                    <i class="fa-regular fa-calendar me-1"></i> @item.Flight?.DepartureTime.ToString("dd MMMM yyyy")
                                </div>
                            </div>
                        </div>

                        <div class="card-body py-2 d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-center mb-3 bg-light rounded-3 p-2 border">
                                <div>
                                    <small class="text-muted text-uppercase fw-bold d-block" style="font-size: 0.65rem;">Cod Referință</small>
                                    <span class="font-monospace fw-bold text-dark small">@(item.TransactionId ?? "Nealocat")</span>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted text-uppercase fw-bold d-block" style="font-size: 0.65rem;">Status</small>
                                    @if (item.PaymentStatus == "Anulat")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                            <i class="fa-solid fa-ban me-1"></i> Anulat
                                        </span>
                                    }
                                    else if (item.PaymentStatus == "Paid")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">
                                            <i class="fa-solid fa-check me-1"></i> Plătit
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow-sm">
                                            <i class="fa-solid fa-clock me-1"></i> În așteptare
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="flex-grow-1">
                                <small class="text-muted text-uppercase fw-bold mb-2 d-block" style="font-size: 0.7rem;"><i class="fa-solid fa-users me-1"></i> Pasageri (@item.Passengers?.Count)</small>
                                <div class="overflow-auto pe-2" style="max-height: 140px;">
                                    @if (item.Passengers != null && item.Passengers.Any())
                                    {
                                        foreach (var p in item.Passengers)
                                        {
                                            <div class="border-bottom pb-2 mb-2 last-border-0">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <span class="fw-bold text-dark small">@p.FullName</span>
                                                        <div class="text-muted" style="font-size: 0.7rem;">Document: @(string.IsNullOrEmpty(p.PassportNumber) ? "Necunoscut" : p.PassportNumber)</div>
                                                    </div>
                                                    <span class="badge @(string.IsNullOrEmpty(p.SeatNumber) ? "bg-secondary" : "bg-warning text-dark")">
                                                        Loc: @(string.IsNullOrEmpty(p.SeatNumber) ? "-" : p.SeatNumber)
                                                    </span>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-muted small fst-italic">Datele pasagerilor nu sunt disponibile.</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-top-0 pt-3 pb-4">
                            @if (isPast)
                            {
                                @if (item.PaymentStatus == "Paid")
                                {
                                    <button class="btn btn-secondary w-100 rounded-pill mb-2 fw-bold" disabled>
                                        <i class="fa-solid fa-plane-arrival me-1"></i> Călătorie Efectuată
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-danger w-100 rounded-pill mb-2 fw-bold opacity-75" disabled>
                                        <i class="fa-solid fa-ban me-1"></i> Rezervare Expirată
                                    </button>
                                }
                            }
                            else
                            {
                                @if (item.PaymentStatus == "Pending")
                                {
                                    <a asp-page="./Payment" asp-route-bookingId="@item.ID" class="btn btn-warning w-100 rounded-pill mb-2 fw-bold text-uppercase">
                                        <i class="fa-solid fa-credit-card me-1"></i> Finalizează Plata
                                    </a>
                                }
                                else if (item.PaymentStatus == "Paid")
                                {
                                    bool allCheckedIn = item.Passengers != null && item.Passengers.All(p => p.IsCheckedIn);

                                    if (!allCheckedIn)
                                    {
                                        <a asp-page="./CheckIn" asp-route-bookingId="@item.ID" class="btn btn-success w-100 rounded-pill mb-2 fw-bold text-uppercase shadow-sm">
                                            <i class="fa-solid fa-passport me-1"></i> Check-in Online
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="./Confirmation" asp-route-bookingId="@item.ID" class="btn btn-outline-primary w-100 rounded-pill mb-2 fw-bold">
                                            <i class="fa-solid fa-qrcode me-1"></i> Boarding Pass
                                        </a>
                                    }
                                }
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2 justify-content-center mt-2 border-top pt-3">
                                    <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-warning rounded-pill px-4 fw-bold" title="Editează">
                                        <i class="fa-solid fa-pen me-1"></i> Editează
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-pill px-4 fw-bold" title="Șterge">
                                        <i class="fa-solid fa-trash me-1"></i> Șterge
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    /* Eliminăm bordura de la ultimul pasager din listă */
    .last-border-0:last-child {
        border-bottom: none !important;
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }
</style>