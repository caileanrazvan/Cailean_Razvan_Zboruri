@page
@model Cailean_Razvan_Zboruri.Pages.Booking.PaymentModel
@{
    ViewData["Title"] = "Securizare Plată";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary text-white p-4 text-center">
                    <i class="fa-solid fa-lock fs-1 mb-2 text-warning"></i>
                    <h3 class="fw-bold mb-0">Plată Securizată</h3>
                    <p class="text-white-50 small mb-0">Zbor @Model.CurrentBooking.Flight.DepartureAirport.IataCode <i class="fa-solid fa-arrow-right mx-1"></i> @Model.CurrentBooking.Flight.ArrivalAirport.IataCode</p>
                </div>

                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <span class="fs-5 text-muted">Total de plată:</span>
                        <span class="fs-2 fw-bolder text-dark">@Model.TotalAmount €</span>
                    </div>

                    <form method="post" id="paymentForm">
                        <input type="hidden" name="bookingId" value="@Model.CurrentBooking.ID" />

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Nume pe card</label>
                            <input type="text" class="form-control form-control-lg bg-light" placeholder="Numele exact ca pe card" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold text-uppercase">Număr Card</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-brands fa-cc-visa text-primary fs-4"></i></span>
                                <input type="text" id="cardNumber" class="form-control form-control-lg bg-light" placeholder="0000 0000 0000 0000" maxlength="19" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <label class="form-label text-muted small fw-bold text-uppercase">Expirare</label>
                                <input type="text" id="expDate" class="form-control form-control-lg bg-light" placeholder="LL/AA" maxlength="5" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small fw-bold text-uppercase">Cod CVC</label>
                                <input type="password" id="cvv" class="form-control form-control-lg bg-light" placeholder="***" maxlength="3" required>
                            </div>
                        </div>

                        <button type="submit" id="payButton" class="btn btn-warning btn-lg w-100 fw-bold shadow text-uppercase rounded-pill">
                            Plătește @Model.TotalAmount €
                        </button>

                        <button class="btn btn-warning btn-lg w-100 fw-bold shadow text-uppercase rounded-pill d-none" id="loadingButton" type="button" disabled>
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            Se procesează plata...
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <i class="fa-brands fa-cc-stripe fs-2 text-muted opacity-50 me-2"></i>
                        <i class="fa-brands fa-cc-mastercard fs-2 text-muted opacity-50"></i>
                        <p class="small text-muted mt-2">Toate tranzacțiile sunt criptate folosind standardul SSL 256-bit.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // 1. FORMATĂM NUMĂRUL CARDULUI (Spațiu la fiecare 4 cifre, max 16 cifre reale)
    const cardNumberInput = document.getElementById('cardNumber');
    cardNumberInput.addEventListener('input', function (e) {
        // Păstrăm doar cifrele
        let value = e.target.value.replace(/\D/g, '');

        // Limităm la 16 cifre strict
        if (value.length > 16) {
            value = value.slice(0, 16);
        }

        // Adăugăm un spațiu la fiecare 4 cifre pentru vizualizare (Ex: 1234 5678)
        e.target.value = value.replace(/(\d{4})(?=\d)/g, '$1 ');
    });

    // 2. FORMATĂM DATA DE EXPIRARE (Format LL/AA)
    const expDateInput = document.getElementById('expDate');
    expDateInput.addEventListener('input', function (e) {
        // Păstrăm doar cifrele
        let value = e.target.value.replace(/\D/g, '');

        if (value.length > 4) {
            value = value.slice(0, 4);
        }

        // Dacă avem cel puțin luna introdusă
        if (value.length >= 2) {
            let month = parseInt(value.slice(0, 2));

            // Nu există lună mai mare de 12 sau luna 00
            if (month > 12) month = 12;
            if (month === 0) month = '01';

            let formattedMonth = month.toString().padStart(2, '0');

            // Punem slash-ul automat dacă utilizatorul a trecut de primele 2 cifre
            if (value.length > 2) {
                e.target.value = formattedMonth + '/' + value.slice(2);
            } else {
                // Previne adăugarea slash-ului când dai Delete/Backspace
                e.target.value = formattedMonth + (e.inputType === 'deleteContentBackward' ? '' : '/');
            }
        } else {
            e.target.value = value;
        }
    });

    // 3. FORMATĂM CVV-UL (Doar cifre, strict 3)
    const cvvInput = document.getElementById('cvv');
    cvvInput.addEventListener('input', function (e) {
        let value = e.target.value.replace(/\D/g, ''); // Doar cifre
        if (value.length > 3) {
            value = value.slice(0, 3);
        }
        e.target.value = value;
    });

    // 4. VALIDARE FINALĂ ÎNAINTE DE PLATĂ ȘI SPINNER
    document.getElementById('paymentForm').addEventListener('submit', function(e) {

        // Verificăm lungimea reală (fără spații și slash-uri)
        const rawCard = cardNumberInput.value.replace(/\D/g, '');
        const rawExp = expDateInput.value.replace(/\D/g, '');
        const rawCvv = cvvInput.value.replace(/\D/g, '');

        if (rawCard.length !== 16) {
            e.preventDefault();
            alert('Numărul cardului trebuie să conțină exact 16 cifre!');
            return;
        }

        if (rawExp.length !== 4) {
            e.preventDefault();
            alert('Data expirării trebuie să fie completă (LL/AA)!');
            return;
        }

        if (rawCvv.length !== 3) {
            e.preventDefault();
            alert('Codul CVC trebuie să conțină exact 3 cifre!');
            return;
        }

        // Dacă a trecut toate testele de securitate, ascundem butonul și arătăm Spinner-ul
        document.getElementById('payButton').classList.add('d-none');
        document.getElementById('loadingButton').classList.remove('d-none');
    });
</script>