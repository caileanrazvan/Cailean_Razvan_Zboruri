@page
@model Cailean_Razvan_Zboruri.Pages.Booking.CheckInModel
@{
    ViewData["Title"] = "Online Check-in";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="text-center mb-5">
                <i class="fa-solid fa-plane-circle-check display-4 text-success mb-3"></i>
                <h2 class="fw-bold">Check-in Online</h2>
                <p class="text-muted">Revizuiește datele de călătorie, completează documentele și confirmă regulile de securitate.</p>
            </div>

            <form method="post">
                <input type="hidden" name="bookingId" value="@Model.Booking.ID" />

                <div class="card border-0 shadow-sm rounded-4 mb-5">
                    <div class="card-header bg-dark text-white rounded-top-4 py-3 px-4">
                        <h6 class="mb-0 fw-bold text-uppercase tracking-wide"><i class="fa-solid fa-plane-departure me-2"></i>Informații Zbor</h6>
                    </div>
                    <div class="card-body p-4 bg-light">
                        <div class="row text-center align-items-center">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <h2 class="fw-bold mb-0 text-primary">@Model.Booking.Flight.DepartureAirport.IataCode</h2>
                                <span class="text-muted small">@Model.Booking.Flight.DepartureAirport.City</span><br />
                                <span class="fw-bold text-dark">@Model.Booking.Flight.DepartureTime.ToString("HH:mm")</span>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <span class="badge bg-secondary mb-2 px-3 py-2">Zbor #@Model.Booking.Flight.FlightNumber</span>
                                <div class="border-bottom border-2 border-primary position-relative mt-2">
                                    <i class="fa-solid fa-plane text-primary position-absolute top-50 start-50 translate-middle bg-light px-2"></i>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <h2 class="fw-bold mb-0 text-primary">@Model.Booking.Flight.ArrivalAirport.IataCode</h2>
                                <span class="text-muted small">@Model.Booking.Flight.ArrivalAirport.City</span><br />
                                <span class="fw-bold text-dark">@Model.Booking.Flight.ArrivalTime.ToString("HH:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-4"><i class="fa-solid fa-passport me-2 text-primary"></i>Verificare Documente Pasageri</h5>

                @for (int i = 0; i < Model.PassengersData.Count; i++)
                {
                    <input type="hidden" asp-for="PassengersData[i].ID" />

                    <div class="card border-0 shadow-sm rounded-4 mb-4 border-start border-4 border-primary">
                        <div class="card-body p-4 p-md-5">
                            <h6 class="fw-bold mb-4 text-muted border-bottom pb-2">Pasager @(i + 1)</h6>

                            <div class="row g-3 mb-3">
                                <div class="col-md-2">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Titlu</label>
                                    <select asp-for="PassengersData[i].Title" class="form-select bg-light" required>
                                        <option value="Mr.">Mr.</option>
                                        <option value="Mrs.">Mrs.</option>
                                        <option value="Ms.">Ms.</option>
                                        <option value="Child">Copil</option>
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Nume</label>
                                    <input asp-for="PassengersData[i].LastName" class="form-control bg-light fw-bold" required />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Prenume</label>
                                    <input asp-for="PassengersData[i].FirstName" class="form-control bg-light fw-bold" required />
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Data Nașterii</label>
                                    <input asp-for="PassengersData[i].DateOfBirth" class="form-control bg-light" type="date" required />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Seria și Nr. Pașaport</label>
                                    <input asp-for="PassengersData[i].PassportNumber" class="form-control border-danger-subtle bg-white" placeholder="Document Călătorie" required />
                                </div>
                            </div>

                            <div class="bg-light p-3 rounded-3 border">
                                <small class="text-muted text-uppercase fw-bold d-block mb-2"><i class="fa-solid fa-plus-circle me-1"></i>Servicii Extra Selectate</small>
                                <div class="row g-3">
                                    @foreach (var amenity in Model.AvailableAmenities)
                                    {
                                        bool isChecked = Model.PassengersData[i].SelectedAmenitiesIds.Contains(amenity.ID);
                                        <div class="col-auto">
                                            <div class="form-check border bg-white px-3 py-2 rounded shadow-sm">
                                                <input class="form-check-input ms-0 me-2" type="checkbox" name="PassengersData[@i].SelectedAmenitiesIds" value="@amenity.ID" @(isChecked ? "checked" : "") />
                                                <label class="form-check-label small fw-medium">@amenity.Name</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                }

                <h5 class="fw-bold mb-4 mt-5"><i class="fa-solid fa-file-contract me-2 text-danger"></i>Declarație Legală de Securitate</h5>

                <div class="card border-danger-subtle bg-danger-subtle text-danger-emphasis shadow-sm rounded-4 mb-5">
                    <div class="card-body p-4 p-md-5">
                        <p class="mb-3 fw-medium">În conformitate cu reglementările aeronautice internaționale, vă rugăm să confirmați că niciunul dintre pasagerii din această rezervare nu transportă în bagajul de cabină sau de cală obiecte interzise, incluzând dar fără a se limita la:</p>

                        <ul class="mb-4 text-dark opacity-75">
                            <li class="mb-2">Substanțe explozive, materiale inflamabile sau gaze comprimate.</li>
                            <li class="mb-2">Baterii cu litiu deteriorate sau dispozitive electronice rechemate de producător (acestea necesită declarare la poartă).</li>
                            <li class="mb-2">Arme de foc, obiecte ascuțite, contondente sau unelte de lucru (permise exclusiv în bagajul de cală înregistrat).</li>
                            <li>Substanțe chimice, toxice sau materiale radioactive.</li>
                        </ul>

                        <div class="bg-white p-3 p-md-4 rounded-4 border border-danger-subtle shadow-sm">
                            <div class="form-check">
                                <input class="form-check-input border-danger shadow-none" type="checkbox" id="securityCheck" style="transform: scale(1.3); margin-top: 0.3rem;" required>
                                <label class="form-check-label fw-bold text-dark ms-2" for="securityCheck">
                                    Confirm pe propria răspundere că am verificat documentele de călătorie (Pașaport/CI) ale tuturor pasagerilor și că respect cu strictețe normele de securitate ale aviației civile.
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-5">
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Anulează</a>
                    <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow rounded-pill text-uppercase">
                        <i class="fa-solid fa-qrcode me-2"></i> Finalizează & Emite Biletele
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>