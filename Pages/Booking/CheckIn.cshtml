@page
@model Cailean_Razvan_Zboruri.Pages.Booking.CheckInModel
@{
    ViewData["Title"] = "Online Check-in";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="text-center mb-5">
                <i class="fa-solid fa-plane-circle-check display-4 text-success mb-3"></i>
                <h2 class="fw-bold">Check-in Online</h2>
                <p class="text-muted">Revizuiește datele de călătorie, completează documentele și confirmă regulile de securitate.</p>
            </div>

            <form method="post">
                <input type="hidden" name="bookingId" value="@Model.Booking.ID" />

                <!-- Card Informații Zbor -->
                <div class="card border-0 shadow-sm rounded-4 mb-5">
                    <div class="card-header bg-dark text-white rounded-top-4 py-3 px-4">
                        <h6 class="mb-0 fw-bold text-uppercase tracking-wide"><i class="fa-solid fa-plane-departure me-2"></i>Informații Zbor</h6>
                    </div>
                    <div class="card-body p-4 bg-light">
                        <div class="row text-center align-items-center">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <h2 class="fw-bold mb-0 text-primary">@Model.Booking.Flight.DepartureAirport.IataCode</h2>
                                <div class="fw-bold small">@Model.Booking.Flight.DepartureAirport.Name</div>
                                <span class="text-muted small">@Model.Booking.Flight.DepartureAirport.City</span><br />
                                <span class="fw-bold text-dark">@Model.Booking.Flight.DepartureTime.ToString("HH:mm")</span>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <span class="badge bg-secondary mb-2 px-3 py-2">Zbor #@Model.Booking.Flight.FlightNumber</span>
                                <div class="border-bottom border-2 border-primary position-relative mt-2">
                                    <i class="fa-solid fa-plane text-primary position-absolute top-50 start-50 translate-middle bg-light px-2"></i>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <h2 class="fw-bold mb-0 text-primary">@Model.Booking.Flight.ArrivalAirport.IataCode</h2>
                                <div class="fw-bold small">@Model.Booking.Flight.ArrivalAirport.Name</div>
                                <span class="text-muted small">@Model.Booking.Flight.ArrivalAirport.City</span><br />
                                <span class="fw-bold text-dark">@Model.Booking.Flight.ArrivalTime.ToString("HH:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-4"><i class="fa-solid fa-passport me-2 text-primary"></i>Verificare Documente Pasageri</h5>

                @for (int i = 0; i < Model.PassengersData.Count; i++)
                {
                    <input type="hidden" asp-for="PassengersData[i].ID" />

                    <div class="card border-0 shadow-sm rounded-4 mb-4 border-start border-4 border-primary">
                        <div class="card-body p-4 p-md-5">
                            <h6 class="fw-bold mb-4 text-muted border-bottom pb-2">Pasager @(i + 1)</h6>

                            <div class="row g-3 mb-3">
                                <div class="col-md-2">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Titlu</label>
                                    <select asp-for="PassengersData[i].Title" class="form-select bg-light" required>
                                        <option value="Mr.">Mr.</option>
                                        <option value="Mrs.">Mrs.</option>
                                        <option value="Ms.">Ms.</option>
                                        <option value="Child">Copil</option>
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Nume</label>
                                    <input asp-for="PassengersData[i].LastName" class="form-control bg-light fw-bold" required />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Prenume</label>
                                    <input asp-for="PassengersData[i].FirstName" class="form-control bg-light fw-bold" required />
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Data Nașterii</label>
                                    <input asp-for="PassengersData[i].DateOfBirth" class="form-control bg-light" type="date" required />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Seria și Nr. Pașaport</label>
                                    <input asp-for="PassengersData[i].PassportNumber" class="form-control border-danger-subtle bg-white" placeholder="Document Călătorie" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-warning small fw-bold text-uppercase">Loc</label>
                                    <!-- AICI AM ADĂUGAT CLASA 'passenger-seat-input' PENTRU JS -->
                                    <input asp-for="PassengersData[i].SeatNumber" class="form-control border-warning bg-warning-subtle text-center fw-bold fs-5 passenger-seat-input" data-passenger-index="@i" readonly required />
                                </div>
                            </div>

                            <!-- ÎNLOCUIEȘTE ACEASTĂ ZONĂ ÎN CHECKIN.CSHTML -->
                            <div class="bg-light p-3 rounded-4 border border-primary-subtle">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-suitcase-rolling text-primary me-2"></i>Servicii Extra Achiziționate</h6>

                                @{
                                    // Filtrăm doar serviciile pe care pasagerul le-a selectat la rezervare
                                    var passengerAmenities = Model.AvailableAmenities
                                    .Where(a => Model.PassengersData[i].SelectedAmenitiesIds.Contains(a.ID))
                                    .ToList();
                                }

                                @if (passengerAmenities.Any())
                                {
                                    <div class="row g-2">
                                        @foreach (var amenity in passengerAmenities)
                                        {
                                            <!-- Păstrăm ID-urile ascunse ca să nu se piardă la submit -->
                                            <input type="hidden" name="PassengersData[@i].SelectedAmenitiesIds" value="@amenity.ID" />

                                            <div class="col-md-6">
                                                <div class="card border border-2 border-primary-subtle rounded-3 h-100 bg-white" style="background-color: rgba(0, 82, 212, 0.05) !important;">
                                                    <div class="row g-0 align-items-center h-100">
                                                        <div class="col-3 h-100">
                                                            <img src="@(string.IsNullOrEmpty(amenity.ImageUrl) ? "/images/default-service.jpg" : amenity.ImageUrl)" class="img-fluid rounded-start-3 h-100" style="object-fit: cover; min-height: 70px;" alt="">
                                                        </div>
                                                        <div class="col-9">
                                                            <div class="card-body p-2">
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <span class="fw-bold text-primary small">@amenity.Name</span>
                                                                    <span class="badge bg-success-subtle text-success rounded-pill px-2">
                                                                        <i class="fa-solid fa-check me-1"></i>Inclus
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small fw-medium">
                                        <i class="fa-solid fa-circle-info text-primary me-1"></i> Acest pasager nu a selectat servicii extra.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- HARTA AVIONULUI -->
                <h5 class="fw-bold mb-4 mt-5"><i class="fa-solid fa-chair me-2 text-primary"></i>Modificare Locuri (Opțional)</h5>

                <div class="card border-0 shadow-sm rounded-4 mb-5">
                    <div class="card-body p-4 p-md-5 text-center">
                        <p class="text-muted small mb-4">Dacă dorești, poți schimba locurile selectate pe harta de mai jos. Fă click pe un loc selectat pentru a-l elibera, apoi alege altul.</p>

                        <div class="d-flex justify-content-center gap-4 mb-4 small fw-bold">
                            <div><div class="seat-legend available border"></div> Disponibil</div>
                            <div><div class="seat-legend selected bg-primary"></div> Selectat</div>
                            <div><div class="seat-legend occupied bg-secondary text-white border-0"><i class="fa-solid fa-xmark" style="font-size:10px;"></i></div> Ocupat</div>
                        </div>

                        <div class="plane-fuselage mx-auto p-4 rounded-5" style="max-width: 400px; background-color: #f8f9fa; border: 2px solid #e9ecef;">
                            <div id="seatMap" class="d-flex flex-column gap-2"></div>
                        </div>
                    </div>
                </div>

                <!-- DECLARAȚIE LEGALĂ -->
                <h5 class="fw-bold mb-4 mt-5"><i class="fa-solid fa-file-contract me-2 text-danger"></i>Declarație Legală de Securitate</h5>

                <div class="card border-danger-subtle bg-danger-subtle text-danger-emphasis shadow-sm rounded-4 mb-5">
                    <div class="card-body p-4 p-md-5">
                        <p class="mb-3 fw-medium">În conformitate cu reglementările aeronautice internaționale, vă rugăm să confirmați că niciunul dintre pasagerii din această rezervare nu transportă în bagajul de cabină sau de cală obiecte interzise, incluzând dar fără a se limita la:</p>

                        <ul class="mb-4 text-dark opacity-75">
                            <li class="mb-2">Substanțe explozive, materiale inflamabile sau gaze comprimate.</li>
                            <li class="mb-2">Baterii cu litiu deteriorate sau dispozitive electronice rechemate de producător (acestea necesită declarare la poartă).</li>
                            <li class="mb-2">Arme de foc, obiecte ascuțite, contondente sau unelte de lucru (permise exclusiv în bagajul de cală înregistrat).</li>
                            <li>Substanțe chimice, toxice sau materiale radioactive.</li>
                        </ul>

                        <div class="bg-white p-3 p-md-4 rounded-4 border border-danger-subtle shadow-sm">
                            <div class="form-check">
                                <input class="form-check-input border-danger shadow-none" type="checkbox" id="securityCheck" style="transform: scale(1.3); margin-top: 0.3rem;" required>
                                <label class="form-check-label fw-bold text-dark ms-2" for="securityCheck">
                                    Confirm pe propria răspundere că am verificat documentele de călătorie (Pașaport/CI) ale tuturor pasagerilor și că respect cu strictețe normele de securitate ale aviației civile.
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-5">
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Anulează</a>
                    <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow rounded-pill text-uppercase">
                        <i class="fa-solid fa-qrcode me-2"></i> Finalizează & Emite Biletele
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<style>
    /* Stilurile pentru harta avionului */
    .seat {
        width: 40px;
        height: 40px;
        border: 2px solid #0052D4;
        border-radius: 8px 8px 4px 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: bold;
        color: #0052D4;
        transition: all 0.2s;
        background-color: white;
    }

        .seat:hover:not(.occupied) {
            background-color: #e0ebff;
            transform: translateY(-2px);
        }

        .seat.selected {
            background-color: #0052D4;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 82, 212, 0.3);
        }

        .seat.occupied {
            background-color: #cbd5e1;
            border-color: #cbd5e1;
            color: white;
            cursor: not-allowed;
        }

    .aisle-number {
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #94a3b8;
    }

    .seat-legend {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        vertical-align: middle;
        margin-right: 5px;
    }
</style>

@section Scripts {
    <script>
        const occupiedSeats = @Html.Raw(Json.Serialize(Model.OccupiedSeats));
        const maxPassengers = @Model.PassengersData.Count;
        let selectedSeats = [];

        // 1. Preluăm locurile deja asignate la încărcarea paginii
        document.querySelectorAll('.passenger-seat-input').forEach(input => {
            if (input.value) {
                selectedSeats.push(input.value);
            }
        });

        const rows = 30;
        const cols = ['A', 'B', 'C', 'D', 'E'];
        const seatMapContainer = document.getElementById('seatMap');

        // 2. Generăm Harta Avionului
        for (let i = 1; i <= rows; i++) {
            const rowDiv = document.createElement('div');
            rowDiv.className = 'd-flex justify-content-center gap-2';

            cols.forEach((col, index) => {
                const seatId = `${i}${col}`; // Ex: 12B
                const isOccupied = occupiedSeats.includes(seatId);
                const isSelectedAlready = selectedSeats.includes(seatId);

                // Creăm scaunul
                const seat = document.createElement('div');
                seat.className = `seat ${isOccupied ? 'occupied' : ''} ${isSelectedAlready ? 'selected' : ''}`;
                seat.innerText = isOccupied ? 'X' : col;
                seat.dataset.seat = seatId;

                // Adăugăm Culoarul după coloana B (index 1)
                if (index === 2) {
                    const aisle = document.createElement('div');
                    aisle.className = 'aisle-number';
                    aisle.innerText = i;
                    rowDiv.appendChild(aisle);
                }

                // Click Event pentru selecție/deselectare
                if (!isOccupied) {
                    seat.addEventListener('click', function() {
                        toggleSeat(this, seatId);
                    });
                }

                rowDiv.appendChild(seat);
            });

            seatMapContainer.appendChild(rowDiv);
        }

        function toggleSeat(seatElement, seatId) {
            const index = selectedSeats.indexOf(seatId);

            if (index > -1) {
                // Deselectare
                selectedSeats.splice(index, 1);
                seatElement.classList.remove('selected');
            } else {
                // Selectare
                if (selectedSeats.length < maxPassengers) {
                    selectedSeats.push(seatId);
                    seatElement.classList.add('selected');
                } else {
                    alert(`Poți selecta maxim ${maxPassengers} locuri! Deselectează un loc pe care îl ai deja pentru a alege altul.`);
                }
            }
            updateHiddenInputs();
        }

        function updateHiddenInputs() {
            // Curățăm toate input-urile vizibile ale pasagerilor
            document.querySelectorAll('.passenger-seat-input').forEach(input => input.value = '');

            // Punem locurile selectate fix în căsuțele fiecărui pasager
            selectedSeats.forEach((seat, index) => {
                const input = document.querySelector(`.passenger-seat-input[data-passenger-index="${index}"]`);
                if (input) {
                    input.value = seat;
                }
            });
        }

        // Validare finală înainte de a trimite Check-in-ul
        document.querySelector('form').addEventListener('submit', function(e) {
            if (selectedSeats.length < maxPassengers) {
                e.preventDefault();
                alert(`Atenție! Pasagerii tăi au nevoie de locuri. Ai selectat doar ${selectedSeats.length} din ${maxPassengers}.`);
                document.getElementById('seatMap').scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
}