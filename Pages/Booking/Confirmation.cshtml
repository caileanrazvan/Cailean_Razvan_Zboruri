@page
@model Cailean_Razvan_Zboruri.Pages.Booking.ConfirmationModel
@{
    ViewData["Title"] = "Confirmare Rezervare";

    // --- CALCUL DURATĂ ZBOR ---
    TimeSpan duration = Model.Booking.Flight.ArrivalTime - Model.Booking.Flight.DepartureTime;
    string formattedDuration = $"{(int)duration.TotalHours}h {duration.Minutes:D2}m";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <div class="display-1 text-success mb-3">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <h1 class="fw-bold">Rezervare Confirmată!</h1>
        <p class="lead text-muted">Cod Referință: <span class="badge bg-dark">@Model.Booking.TransactionId</span></p>
        <p>Un e-mail de confirmare a fost trimis la <strong>@Model.Booking.ContactEmail</strong></p>

        <button onclick="window.print()" class="btn btn-outline-primary mt-3 no-print">
            <i class="fa-solid fa-print me-2"></i> Printează Biletele
        </button>
    </div>

    <h3 class="fw-bold mb-4 border-bottom pb-2"><i class="fa-solid fa-ticket text-primary me-2"></i>Biletele Tale</h3>

    @foreach (var passenger in Model.Booking.Passengers)
    {
        <div class="boarding-pass mb-5 shadow-sm">
            <div class="row g-0">
                <div class="col-md-9 main-ticket p-4 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-plane text-primary fs-3 me-2"></i>
                            <span class="fw-bold fs-4 text-uppercase">Angel Airlines</span>
                        </div>
                        <div class="text-end">
                            <small class="text-muted d-block text-uppercase">Clasa</small>
                            <span class="fw-bold">Economic</span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-5">
                            <h2 class="fw-bolder mb-0">@Model.Booking.Flight.DepartureAirport.IataCode</h2>
                            <div class="text-muted small fw-bold">@Model.Booking.Flight.DepartureAirport.Name</div>
                            <div class="text-muted small" style="font-size: 0.7rem;">@Model.Booking.Flight.DepartureAirport.City</div>
                            <div class="fw-bold mt-2">@Model.Booking.Flight.DepartureTime.ToString("HH:mm")</div>
                        </div>

                        <div class="col-2 text-center align-self-center px-0">
                            <div class="text-muted small fw-bold mb-1">@formattedDuration</div>
                            <div class="border-top border-2 border-warning position-relative mt-2">
                                <i class="fa-solid fa-plane text-warning position-absolute top-50 start-50 translate-middle bg-white px-2"></i>
                            </div>
                        </div>

                        <div class="col-5 text-end">
                            <h2 class="fw-bolder mb-0">@Model.Booking.Flight.ArrivalAirport.IataCode</h2>
                            <div class="text-muted small fw-bold">@Model.Booking.Flight.ArrivalAirport.Name</div>
                            <div class="text-muted small" style="font-size: 0.7rem;">@Model.Booking.Flight.ArrivalAirport.City</div>
                            <div class="fw-bold mt-2">@Model.Booking.Flight.ArrivalTime.ToString("HH:mm")</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-4 border-end">
                            <small class="text-muted d-block text-uppercase">Pasager</small>
                            <span class="fw-bold">@passenger.FullName</span>
                        </div>
                        <div class="col-3 border-end ps-3">
                            <small class="text-muted d-block text-uppercase">Data</small>
                            <span class="fw-bold">@Model.Booking.Flight.DepartureTime.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="col-3 border-end ps-3">
                            <small class="text-muted d-block text-uppercase">Zbor</small>
                            <span class="fw-bold text-primary">#@Model.Booking.Flight.FlightNumber</span>
                        </div>
                        <div class="col-2 ps-3">
                            <small class="text-muted d-block text-uppercase">Loc</small>
                            <span class="fw-bold fs-5 text-warning">@passenger.SeatNumber</span>
                        </div>
                    </div>

                    <div class="mt-3 px-3 py-2 bg-light border rounded-3 text-muted small d-flex align-items-center">
                        <i class="fa-solid fa-suitcase-rolling fs-5 text-primary me-3"></i>
                        <div>
                            <strong class="text-dark">Bagaj Inclus:</strong> 1 Bagaj de cabină (max. 10 kg) & 1 Articol personal (rucsac/geantă).
                        </div>
                    </div>

                    @if (passenger.Amenities != null && passenger.Amenities.Any())
                    {
                        <div class="mt-3 pt-3 border-top">
                            <small class="text-muted text-uppercase fw-bold d-block mb-2" style="font-size: 0.7rem;">Servicii adiționale:</small>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var am in passenger.Amenities)
                                {
                                    <span class="badge bg-white text-dark border shadow-sm"><i class="fa-solid fa-check text-success me-1"></i>@am.Name</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="col-md-3 stub-ticket p-4 bg-light border-start d-none d-md-block d-print-block text-center position-relative">
                    <div class="perforation-circles"></div>
                    <small class="text-muted text-uppercase d-block mb-3">Boarding Pass</small>
                    <div class="fs-4 fw-bold mb-1">@passenger.SeatNumber</div>
                    <div class="mb-4 small fw-bold text-danger">GATE OPENS: @Model.Booking.Flight.DepartureTime.AddMinutes(-45).ToString("HH:mm")</div>

                    <div class="qr-placeholder mx-auto mb-3">
                        <i class="fa-solid fa-qrcode display-1 opacity-25"></i>
                    </div>
                    <div class="small text-muted font-monospace">@Model.Booking.TransactionId</div>
                </div>
            </div>
        </div>
    }

    <div class="text-center mt-5 no-print">
        <a asp-page="/Index" class="btn btn-primary btn-lg px-5 rounded-pill">Înapoi la Pagina Principală</a>
    </div>
</div>

<style>
    .boarding-pass {
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #dee2e6;
    }

    .main-ticket {
        border-right: 2px dashed #dee2e6;
    }

    .stub-ticket {
        background-image: radial-gradient(circle at 0 50%, transparent 10px, #f8f9fa 10px);
    }

    /* Cercurile care simulează perforația */
    .perforation-circles {
        position: absolute;
        left: -11px;
        top: 0;
        bottom: 0;
        width: 22px;
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        align-items: center;
        z-index: 10;
    }

    /* Regulile speciale pentru Imprimantă */
    @@media print {
        body {
            background: white;
            /* Forțează browserul să printeze fundalurile gri/colorate și perforațiile */
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .no-print, .navbar, footer {
            display: none !important;
        }

        .boarding-pass {
            break-inside: avoid;
            box-shadow: none !important;
            border: 1px solid #ccc !important;
            margin-bottom: 20px !important;
        }

        .main-ticket {
            width: 75% !important;
            float: left !important;
        }

        .stub-ticket {
            width: 25% !important;
            float: left !important;
            display: block !important;
            border-left: 2px dashed #ccc !important;
        }
    }
</style>