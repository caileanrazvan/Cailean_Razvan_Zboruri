@page
@model Cailean_Razvan_Zboruri.Pages.Bookings.DeleteModel
@{
    ViewData["Title"] = "Anulare Rezervare";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card border-danger shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger text-white p-4 text-center">
                    <i class="fa-solid fa-triangle-exclamation display-4 mb-3"></i>
                    <h2 class="fw-bold mb-0">Anulare Rezervare</h2>
                    <p class="mb-0 text-white-50">Această acțiune este ireversibilă!</p>
                </div>

                <div class="card-body p-4 text-center">
                    <h5 class="text-muted mb-4">Ești sigur că vrei să anulezi această rezervare?</h5>

                    <div class="bg-light p-3 rounded-3 text-start mb-4 border">
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                            <span class="text-muted">Referință:</span>
                            <span class="fw-bold">@(Model.Booking.TransactionId ?? "Neplătit")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                            <span class="text-muted">Zbor:</span>
                            <span class="fw-bold">@Model.Booking.Flight.DepartureAirport.IataCode <i class="fa-solid fa-arrow-right mx-1 small"></i> @Model.Booking.Flight.ArrivalAirport.IataCode</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                            <span class="text-muted">Data Zborului:</span>
                            <span class="fw-bold">@Model.Booking.Flight.DepartureTime.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Număr Pasageri:</span>
                            <span class="fw-bold">@Model.Booking.Passengers.Count</span>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Booking.ID" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">M-am răzgândit</a>
                            <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill fw-bold shadow-sm">
                                <i class="fa-solid fa-trash-can me-2"></i> Confirmă Anularea
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>