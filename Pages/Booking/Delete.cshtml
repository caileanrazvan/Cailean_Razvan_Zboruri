@page
@model Cailean_Razvan_Zboruri.Pages.Booking.DeleteModel
@{
    ViewData["Title"] = "Șterge Rezervare";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="alert alert-danger shadow-sm text-center">
            <h4><i class="fa-solid fa-triangle-exclamation"></i> Atenție!</h4>
            <p>Ești sigur că vrei să anulezi și să ștergi definitiv această rezervare?</p>
        </div>

        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Date Rezervare</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Pasager</dt>

                    <dt class="col-sm-4 text-muted">Zbor</dt>
                    <dd class="col-sm-8"><span class="badge bg-dark">@Model.Booking.Flight.FlightNumber</span></dd>

                    <dt class="col-sm-4 text-muted">Data Rezervării</dt>
                    <dd class="col-sm-8">@Model.Booking.BookingDate.ToString("dd MMM yyyy, HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer bg-light d-flex justify-content-end gap-2">
                <form method="post">
                    <input type="hidden" asp-for="Booking.ID" />
                    <a asp-page="./Index" class="btn btn-secondary">Anulează</a>
                    <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Confirmă Ștergerea</button>
                </form>
            </div>
        </div>
    </div>
</div>