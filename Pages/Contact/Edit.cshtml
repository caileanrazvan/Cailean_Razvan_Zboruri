@page
@model Cailean_Razvan_Zboruri.Pages.Contact.EditModel
@{
    ViewData["Title"] = "Editează Contact";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-warning text-dark p-4">
                    <h3 class="fw-bold mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>Editează Datele de Contact</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="ContactInfo.ID" />

                        <div class="mb-4">
                            <label asp-for="ContactInfo.Description" class="form-label fw-bold text-muted small text-uppercase">Mesaj de Întâmpinare (Descriere)</label>
                            <textarea asp-for="ContactInfo.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="ContactInfo.Description" class="text-danger"></span>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="ContactInfo.Phone" class="form-label fw-bold text-muted small text-uppercase">Telefon</label>
                                <input asp-for="ContactInfo.Phone" class="form-control" />
                                <span asp-validation-for="ContactInfo.Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ContactInfo.Email" class="form-label fw-bold text-muted small text-uppercase">E-mail</label>
                                <input asp-for="ContactInfo.Email" class="form-control" />
                                <span asp-validation-for="ContactInfo.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ContactInfo.WorkingHours" class="form-label fw-bold text-muted small text-uppercase">Program de Lucru</label>
                                <input asp-for="ContactInfo.WorkingHours" class="form-control" />
                                <span asp-validation-for="ContactInfo.WorkingHours" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ContactInfo.Address" class="form-label fw-bold text-muted small text-uppercase">Adresă Sediu</label>
                                <input asp-for="ContactInfo.Address" class="form-control" />
                                <span asp-validation-for="ContactInfo.Address" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Anulează</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold shadow rounded-pill text-uppercase">
                                <i class="fa-solid fa-save me-2"></i> Salvează Modificările
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}