@page
@model Cailean_Razvan_Zboruri.Pages.Flight.IndexModel
@{
    ViewData["Title"] = "Rezultate Căutare Zboruri";
}

@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-end mt-4 mb-2">
        <a asp-page="./Create" class="btn btn-success fw-bold rounded-pill shadow-sm">
            <i class="fa-solid fa-plus-circle me-2"></i>Adaugă Zbor Nou
        </a>
    </div>
}

<div class="bg-primary text-white p-4 rounded-4 shadow-sm mb-4 mt-3 d-flex justify-content-between align-items-center"
     style="background: linear-gradient(135deg, #0052D4 0%, #4364F7 100%);">
    <div>
        <h4 class="mb-1 fw-bold">
            @Model.DepartureCityName
            <i class="fa-solid fa-arrow-right mx-2 text-warning"></i>
            @Model.ArrivalCityName
        </h4>
        <div class="text-white-50 small">
            <i class="fa-regular fa-calendar me-1"></i> @(Model.SearchDate?.ToString("dd MMM yyyy") ?? "Orice dată")
            <span class="mx-2">|</span>
            <i class="fa-solid fa-users me-1"></i> @Model.Passengers Pasageri
        </div>
    </div>
    <div>
        <a asp-page="/Index" class="btn btn-outline-light rounded-pill px-4">Modifică Căutarea</a>
    </div>
</div>

<div class="row">
    <div class="col-md-3 d-none d-md-block">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filtre</h5>
                <hr />
                <p class="text-muted small">Am găsit <strong>@Model.Flight.Count</strong> zboruri potrivite pentru criteriile tale.</p>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        @if (Model.Flight.Count == 0)
        {
            <div class="text-center py-5">
                <img src="~/images/logo.svg" alt="No flights" width="60" class="mb-3 opacity-50 filter-grayscale" />
                <h4 class="text-muted fw-bold">Nu am găsit niciun zbor.</h4>
                <p class="text-muted">Încearcă să selectezi o altă dată sau altă destinație.</p>
                <a asp-page="/Index" class="btn btn-primary mt-2">Înapoi la Căutare</a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Flight)
            {
                <div class="card border-0 shadow-sm mb-4 rounded-4 flight-list-card transition">
                    <div class="card-body p-0">
                        <div class="row g-0 align-items-center">

                            <div class="col-md-9 p-4">
                                <div class="d-flex align-items-center justify-content-between">

                                    <div class="text-center" style="width: 120px;">
                                        <h3 class="fw-bold text-dark mb-0">@item.DepartureTime.ToString("HH:mm")</h3>
                                        <div class="text-primary small fw-bold mb-2">@item.DepartureTime.ToString("dd MMM yyyy")</div>
                                        <div class="text-muted small">@item.DepartureAirport.City</div>
                                        <div class="badge bg-light text-dark mt-1 border">@item.DepartureAirport.IataCode</div>
                                    </div>

                                    <div class="flex-grow-1 px-4 text-center position-relative">
                                        <div class="text-muted small fw-bold mb-1">Direct</div>
                                        <div class="border-top border-2 border-primary-subtle position-relative">
                                            <i class="fa-solid fa-plane text-primary position-absolute top-50 start-50 translate-middle bg-white px-2"></i>
                                        </div>
                                    </div>

                                    <div class="text-center" style="width: 120px;">
                                        <h3 class="fw-bold text-dark mb-0">@item.ArrivalTime.ToString("HH:mm")</h3>
                                        <div class="text-primary small fw-bold mb-2">@item.ArrivalTime.ToString("dd MMM yyyy")</div>
                                        <div class="text-muted small">@item.ArrivalAirport.City</div>
                                        <div class="badge bg-light text-dark mt-1 border">@item.ArrivalAirport.IataCode</div>
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-3 bg-light p-4 h-100 d-flex flex-column justify-content-center align-items-center border-start rounded-end-4 position-relative" style="min-height: 160px;">
                                <div class="text-muted small mb-1">Preț pe pasager</div>
                                <h2 class="text-success fw-bolder mb-3">@item.BasePrice €</h2>
                                <a asp-page="/Booking/Create" asp-route-flightId="@item.ID" asp-route-passengers="@Model.Passengers" class="btn btn-primary w-100 fw-bold rounded-pill shadow-sm mb-2">
                                    Alege <i class="fa-solid fa-chevron-right ms-1"></i>
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-1 mt-2 border-top pt-2 w-100 justify-content-center">
                                        <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-xs btn-outline-warning rounded-pill" title="Editează Zborul">
                                            <i class="fa-solid fa-pen small"></i> <span class="small">Edit</span>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-xs btn-outline-danger rounded-pill" title="Șterge Zborul">
                                            <i class="fa-solid fa-trash small"></i> <span class="small">Șterge</span>
                                        </a>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* Stiluri pentru butoanele mici de admin (xs) */
    .btn-xs {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
        line-height: 1;
    }

    .flight-list-card {
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

        .flight-list-card:hover {
            transform: scale(1.01);
            box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1) !important;
        }

    .filter-grayscale {
        filter: grayscale(100%);
    }
</style>