@page
@model Cailean_Razvan_Zboruri.Pages.Flight.IndexModel
@{
    ViewData["Title"] = "Rezultate Căutare Zboruri";
}

@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-end mt-4 mb-2">
        <a asp-page="./Create" class="btn btn-success fw-bold rounded-pill shadow-sm">
            <i class="fa-solid fa-plus-circle me-2"></i>Adaugă Zbor Nou
        </a>
    </div>
}

<div class="bg-primary text-white p-4 rounded-4 shadow-sm mb-4 mt-3 d-flex justify-content-between align-items-center"
     style="background: linear-gradient(135deg, #0052D4 0%, #4364F7 100%);">
    <div>
        <h4 class="mb-1 fw-bold">
            @Model.DepartureCityName
            <i class="fa-solid fa-arrow-right mx-2 text-warning"></i>
            @Model.ArrivalCityName
        </h4>
        <div class="text-white-50 small">
            <i class="fa-regular fa-calendar me-1"></i> @(Model.SearchDate?.ToString("dd MMM yyyy") ?? "Orice dată")
            <span class="mx-2">|</span>
            <i class="fa-solid fa-users me-1"></i> @Model.Passengers Pasageri
        </div>
    </div>
    <div>
        <a asp-page="/Index" class="btn btn-outline-light rounded-pill px-4">Modifică</a>
    </div>
</div>

<div class="row">
    <div class="col-md-3 d-none d-md-block">
        <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-sliders text-primary me-2"></i>Filtre</h5>
                <hr />
                <p class="text-muted small">Am găsit zboruri potrivite pentru criteriile tale.</p>

                <form method="get" class="mt-4">
                    <input type="hidden" name="departureId" value="@Model.CurrentDepartureId" />
                    <input type="hidden" name="arrivalId" value="@Model.CurrentArrivalId" />
                    <input type="hidden" name="flightDate" value="@Model.SearchDate?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="passengers" value="@Model.Passengers" />

                    <label class="form-label small fw-bold text-uppercase text-muted">Sortează după</label>
                    <select name="SortOrder" class="form-select form-select-sm border-2 rounded-3 mb-3" onchange="this.form.submit()">
                        @if (string.IsNullOrEmpty(Model.SortOrder) || Model.SortOrder == "date_asc")
                        {
                            <option value="date_asc" selected>Plecare (mai curând)</option>
                        }
                        else
                        {
                            <option value="date_asc">Plecare (mai curând)</option>
                        }

                        @if (Model.SortOrder == "date_desc")
                        {
                            <option value="date_desc" selected>Plecare (mai târziu)</option>
                        }
                        else
                        {
                            <option value="date_desc">Plecare (mai târziu)</option>
                        }
                        @if (Model.SortOrder == "price_asc")
                        {
                            <option value="price_asc" selected>Preț (crescător)</option>
                        }
                        else
                        {
                            <option value="price_asc">Preț (crescător)</option>
                        }
                        @if (Model.SortOrder == "price_desc")
                        {
                            <option value="price_desc" selected>Preț (descrescător)</option>
                        }
                        else
                        {
                            <option value="price_desc">Preț (descrescător)</option>
                        }
                    </select>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        @if (Model.Flight.Count == 0)
        {
            <div class="text-center py-5">
                <img src="~/images/logo.svg" alt="No flights" width="60" class="mb-3 opacity-50 filter-grayscale" />
                <h4 class="text-muted fw-bold">Nu am găsit niciun zbor.</h4>
                <p class="text-muted">Încearcă să selectezi o altă dată sau altă destinație.</p>
                <a asp-page="/Index" class="btn btn-primary mt-2">Înapoi la Căutare</a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Flight)
            {
                bool isPast = item.DepartureTime < DateTime.Now;

                // --- CALCUL DURATĂ ZBOR ---
                TimeSpan duration = item.ArrivalTime - item.DepartureTime;
                string formattedDuration = $"{(int)duration.TotalHours}h {duration.Minutes:D2}m"; // Ex: 2h 45m

                <div class="card border-0 shadow-sm mb-4 rounded-4 flight-list-card transition @(isPast || item.IsCancelled ? "border border-danger bg-danger-subtle" : "")">

                    @if (item.IsCancelled)
                    {
                        <span class="badge bg-danger ms-2 mt-2 position-absolute" style="z-index: 5;"><i class="fa-solid fa-ban me-1"></i>ANULAT</span>
                    }

                    @if (isPast && !item.IsCancelled)
                    {
                        <div class="position-absolute top-0 start-50 translate-middle-x badge bg-danger shadow-sm" style="margin-top: -10px; z-index: 5;">
                            <i class="fa-solid fa-clock-rotate-left me-1"></i> ZBOR TRECUT (ISTORIC)
                        </div>
                    }

                    <div class="card-body p-0 @(isPast || item.IsCancelled ? "opacity-75" : "")">
                        <div class="row g-0 align-items-center">

                            <div class="col-md-9 p-4">
                                <div class="d-flex align-items-center justify-content-between">

                                    <div class="text-center" style="width: 120px;">
                                        <h3 class="fw-bold text-dark mb-0">@item.DepartureTime.ToString("HH:mm")</h3>
                                        <div class="text-primary small fw-bold mb-2">@item.DepartureTime.ToString("dd MMM yyyy")</div>
                                        <div class="text-dark small fw-bold">@item.DepartureAirport.Name</div>
                                        <div class="text-muted small">@item.DepartureAirport.City</div>
                                        <div class="badge bg-light text-dark mt-1 border">@item.DepartureAirport.IataCode</div>
                                    </div>

                                    <div class="flex-grow-1 px-4 text-center position-relative">
                                        <div class="text-muted small fw-bold mb-1">Direct &bull; @formattedDuration</div>
                                        <div class="border-top border-2 border-primary-subtle position-relative">
                                            <i class="fa-solid fa-plane text-primary position-absolute top-50 start-50 translate-middle bg-white px-2"></i>
                                        </div>
                                    </div>

                                    <div class="text-center" style="width: 120px;">
                                        <h3 class="fw-bold text-dark mb-0">@item.ArrivalTime.ToString("HH:mm")</h3>
                                        <div class="text-primary small fw-bold mb-2">@item.ArrivalTime.ToString("dd MMM yyyy")</div>
                                        <div class="text-dark small fw-bold">@item.ArrivalAirport.Name</div>
                                        <div class="text-muted small">@item.ArrivalAirport.City</div>
                                        <div class="badge bg-light text-dark mt-1 border">@item.ArrivalAirport.IataCode</div>
                                    </div>

                                </div>
                            </div>

                            <div class="col-md-3 bg-light p-4 h-100 d-flex flex-column justify-content-center align-items-center border-start rounded-end-4 position-relative" style="min-height: 160px;">
                                <div class="text-muted small mb-1">Preț pe pasager</div>
                                <h2 class="text-success fw-bolder mb-3">@item.BasePrice €</h2>

                                @if (!isPast && !item.IsCancelled)
                                {
                                    <form method="get" asp-page="/Booking/Create" class="w-100">
                                        <input type="hidden" name="flightId" value="@item.ID" />
                                        <div class="input-group mb-3 bg-white border rounded-pill overflow-hidden shadow-sm">
                                            <span class="input-group-text bg-transparent border-0 text-primary ps-3">
                                                <i class="fa-solid fa-users"></i>
                                            </span>
                                            <select name="passengers" class="form-select border-0 shadow-none fw-bold bg-transparent cursor-pointer">
                                                @for (int p = 1; p <= 9; p++)
                                                {
                                                    if (Model.Passengers == p)
                                                    {
                                                        <option value="@p" selected>@p Pasageri</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@p">@p Pasageri</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100 fw-bold rounded-pill shadow-sm mb-2 text-uppercase tracking-wide transition-hover">
                                            Alege <i class="fa-solid fa-chevron-right ms-1"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100 rounded-pill mb-2 fw-bold" disabled>
                                        @(item.IsCancelled ? "Anulat" : "Indisponibil")
                                    </button>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-1 mt-2 border-top pt-2 w-100 justify-content-center align-items-center">
                                        @if (!item.IsCancelled)
                                        {
                                            <form method="post" asp-page-handler="Cancel" asp-route-id="@item.ID" class="m-0">
                                                <button type="submit" class="btn btn-xs btn-outline-dark rounded-pill shadow-sm" onclick="return confirm('Sigur vrei să ANULEZI acest zbor?');" title="Anulează Zborul">
                                                    <i class="fa-solid fa-ban small"></i> <span class="small">Anulează</span>
                                                </button>
                                            </form>
                                        }
                                        <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-xs btn-outline-warning rounded-pill shadow-sm" title="Editează Zborul">
                                            <i class="fa-solid fa-pen small"></i> <span class="small">Editează</span>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-xs btn-outline-danger rounded-pill shadow-sm" title="Șterge Definitiv Zborul">
                                            <i class="fa-solid fa-trash small"></i> <span class="small">Șterge</span>
                                        </a>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-5 mb-4">
                    <ul class="pagination justify-content-center">

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-start-pill px-4 fw-bold shadow-sm"
                               asp-route-pageIndex="@(Model.CurrentPage - 1)"
                               asp-route-SortOrder="@Model.SortOrder"
                               asp-route-departureId="@Model.CurrentDepartureId"
                               asp-route-arrivalId="@Model.CurrentArrivalId"
                               asp-route-flightDate="@Model.SearchDate?.ToString("yyyy-MM-dd")"
                               asp-route-passengers="@Model.Passengers">
                                <i class="fa-solid fa-chevron-left me-1"></i> Înapoi
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link shadow-sm fw-bold"
                                   asp-route-pageIndex="@i"
                                   asp-route-SortOrder="@Model.SortOrder"
                                   asp-route-departureId="@Model.CurrentDepartureId"
                                   asp-route-arrivalId="@Model.CurrentArrivalId"
                                   asp-route-flightDate="@Model.SearchDate?.ToString("yyyy-MM-dd")"
                                   asp-route-passengers="@Model.Passengers">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-end-pill px-4 fw-bold shadow-sm"
                               asp-route-pageIndex="@(Model.CurrentPage + 1)"
                               asp-route-SortOrder="@Model.SortOrder"
                               asp-route-departureId="@Model.CurrentDepartureId"
                               asp-route-arrivalId="@Model.CurrentArrivalId"
                               asp-route-flightDate="@Model.SearchDate?.ToString("yyyy-MM-dd")"
                               asp-route-passengers="@Model.Passengers">
                                Înainte <i class="fa-solid fa-chevron-right ms-1"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            }
        }
    </div>
</div>

<style>
    /* Stiluri pentru butoanele mici de admin (xs) */
    .btn-xs {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
        line-height: 1;
    }

    .flight-list-card {
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

        .flight-list-card:hover {
            transform: scale(1.01);
            box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1) !important;
        }

    .filter-grayscale {
        filter: grayscale(100%);
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .tracking-wide {
        letter-spacing: 0.5px;
    }
</style>