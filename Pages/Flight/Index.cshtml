@page
@model Cailean_Razvan_Zboruri.Pages.Flight.IndexModel
@{
    ViewData["Title"] = "Zboruri";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fa-solid fa-plane-departure text-primary"></i> Zboruri Disponibile</h1>
    <a asp-page="Create" class="btn btn-success shadow-sm"><i class="fa-solid fa-plus"></i> Adaugă Zbor</a>
</div>

<form asp-page="./Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input type="text" name="searchString" value="@Model.CurrentFilter" class="form-control" placeholder="Caută după destinație sau număr zbor..." />
        <button class="btn btn-primary" type="submit">Caută</button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold">
                    <tr>
                        <th>Zbor</th>
                        <th>Rută</th>
                        <th>Program (Plecare / Sosire)</th>
                        <th>Preț Bază</th>
                        <th class="text-end" style="min-width: 150px;">Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Flight)
                    {
                        <tr>
                            <td class="fw-bold text-primary">
                                <i class="fa-solid fa-ticket"></i> @Html.DisplayFor(modelItem => item.FlightNumber)
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-secondary">@item.DepartureAirport.IataCode</span>
                                    <i class="fa-solid fa-arrow-right-long text-muted"></i>
                                    <span class="badge bg-primary">@item.ArrivalAirport.IataCode</span>
                                </div>
                                <small class="text-muted">@item.ArrivalAirport.City</small>
                            </td>
                            <td>
                                <div><i class="fa-regular fa-clock text-success"></i> @item.DepartureTime.ToString("g")</div>
                                <div><i class="fa-regular fa-clock text-danger"></i> @item.ArrivalTime.ToString("g")</div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-success fs-6">
                                    @Html.DisplayFor(modelItem => item.BasePrice) €
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a asp-page="./Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info" title="Detalii"><i class="fa-solid fa-circle-info"></i></a>
                                    <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-warning" title="Editează"><i class="fa-solid fa-pen"></i></a>
                                    <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger" title="Șterge"><i class="fa-solid fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>