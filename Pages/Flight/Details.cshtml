@page
@model Cailean_Razvan_Zboruri.Pages.Flight.DetailsModel
@{
    ViewData["Title"] = "Detalii Zbor";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0"><i class="fa-solid fa-circle-info"></i> Detalii Zbor: @Model.Flight.FlightNumber</h4>
            </div>
            <div class="card-body">
                <div class="row mb-4 text-center">
                    <div class="col-5">
                        <h5 class="fw-bold text-primary">@Model.Flight.DepartureAirport.City</h5>
                        <span class="badge bg-secondary">@Model.Flight.DepartureAirport.IataCode</span>
                        <div class="mt-2 text-muted">
                            <i class="fa-regular fa-clock"></i> @Model.Flight.DepartureTime.ToString("dd MMM yyyy, HH:mm")
                        </div>
                    </div>
                    <div class="col-2 align-self-center">
                        <i class="fa-solid fa-plane fa-2x text-muted"></i>
                        <i class="fa-solid fa-arrow-right-long d-block mt-2"></i>
                    </div>
                    <div class="col-5">
                        <h5 class="fw-bold text-primary">@Model.Flight.ArrivalAirport.City</h5>
                        <span class="badge bg-secondary">@Model.Flight.ArrivalAirport.IataCode</span>
                        <div class="mt-2 text-muted">
                            <i class="fa-regular fa-clock"></i> @Model.Flight.ArrivalTime.ToString("dd MMM yyyy, HH:mm")
                        </div>
                    </div>
                </div>

                <hr />

                <dl class="row">
                    <dt class="col-sm-4">Preț Bază</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-success fs-5">@Model.Flight.BasePrice €</span>
                    </dd>

                    <dt class="col-sm-4">ID Sistem</dt>
                    <dd class="col-sm-8">@Model.Flight.ID</dd>
                </dl>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-page="./Index" class="btn btn-secondary">Înapoi la listă</a>
                </div>
            </div>
        </div>
    </div>
</div>