@page
@model Cailean_Razvan_Zboruri.Pages.Flight.EditModel
@{
    ViewData["Title"] = "Editează Zbor";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="fa-solid fa-plane-departure"></i> Adaugă Zbor Nou</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Flight.ID" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Flight.FlightNumber" class="form-label fw-bold">Număr Zbor</label>
                            <input asp-for="Flight.FlightNumber" class="form-control" placeholder="Ex: RO301" />
                            <span asp-validation-for="Flight.FlightNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Flight.BasePrice" class="form-label fw-bold">Preț Bază (€)</label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="Flight.BasePrice" class="form-control" />
                            </div>
                            <span asp-validation-for="Flight.BasePrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3 p-3 bg-light rounded mx-1 border">
                        <div class="col-md-6">
                            <label asp-for="Flight.DepartureAirportID" class="form-label fw-bold"><i class="fa-solid fa-plane-departure"></i> Aeroport Plecare</label>
                            <select asp-for="Flight.DepartureAirportID" class="form-select" asp-items="ViewBag.DepartureAirportID"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Flight.ArrivalAirportID" class="form-label fw-bold"><i class="fa-solid fa-plane-arrival"></i> Aeroport Sosire</label>
                            <select asp-for="Flight.ArrivalAirportID" class="form-select" asp-items="ViewBag.ArrivalAirportID"></select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Flight.DepartureTime" class="form-label fw-bold">Data Plecării</label>
                            <input asp-for="Flight.DepartureTime" class="form-control" />
                            <span asp-validation-for="Flight.DepartureTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Flight.ArrivalTime" class="form-label fw-bold">Data Sosirii</label>
                            <input asp-for="Flight.ArrivalTime" class="form-control" />
                            <span asp-validation-for="Flight.ArrivalTime" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-page="Index" class="btn btn-secondary me-md-2">Anulează</a>
                        <input type="submit" value="Salvează Zborul" class="btn btn-success px-4" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}