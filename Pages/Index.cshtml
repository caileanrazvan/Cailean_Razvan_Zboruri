@page
@model IndexModel
@{
    ViewData["Title"] = "AngelAirlines - Zboară cu Îngerii";
}

<div class="position-relative bg-primary text-white text-center py-5 mb-5 rounded-bottom shadow"
     style="background-image: url('/images/clouds_bg.png'); background-size: cover; background-position: center; min-height: 400px;">

    <div class="container py-5">

        <div class="d-flex align-items-center justify-content-center mb-3">
            <img src="~/images/logo.svg" alt="AngelAirlines Logo" width="80" height="80" class="me-3 filter-white" />
            <h1 class="display-3 fw-bold mb-0 text-shadow-elegant">Angel Airlines</h1>
        </div>

        <p class="lead fs-4 mb-0 text-shadow-elegant">Descoperă destinații divine la prețuri pământești.</p>
    </div>
</div>

<style>
    /* Această umbră difuză face textul alb ușor de citit pe orice fundal, fără să adauge cutii inestetice */
    .text-shadow-elegant {
        text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.6);
    }
</style>

<div class="container" style="margin-top: -120px; position: relative; z-index: 10;">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
            <h5 class="text-primary fw-bold mb-4 border-bottom pb-2">
                <i class="fa-solid fa-plane-up"></i> Rezervă Zborul Tău
            </h5>
            <form action="/Flight/Index" method="get">
                <div class="row g-3">
                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Plecare</label>
                        <select name="departureId" class="form-select border-primary-subtle" asp-items="Model.AirportsList">
                            <option value="">Oriunde</option>
                        </select>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Destinație</label>
                        <select name="arrivalId" class="form-select border-primary-subtle" asp-items="Model.AirportsList">
                            <option value="">Oriunde</option>
                        </select>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Dată Plecare</label>
                        <input type="date" name="flightDate" class="form-control border-primary-subtle" />
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Pasageri</label>
                        <input type="number" name="passengers" class="form-control border-primary-subtle" value="1" min="1" max="9" />
                    </div>

                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold text-uppercase shadow">
                            <i class="fa-solid fa-magnifying-glass me-2"></i> Caută Oferte
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container mt-5 pt-4 mb-5">
    <h3 class="text-center fw-bold mb-4 text-primary">Cele mai mici tarife AngelAirlines</h3>
    <div class="row g-4">
        @foreach (var flight in Model.CheapFlights)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition" style="border-radius: 16px; overflow: hidden;">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="badge bg-warning text-dark fw-bold px-3 py-2 rounded-pill shadow-sm">
                                <i class="fa-solid fa-star me-1"></i> Recomandat
                            </span>
                            <h2 class="text-success fw-bolder mb-0">@flight.BasePrice <small class="fs-5">€</small></h2>
                        </div>

                        <div class="bg-light p-3 rounded-4 mb-4 border border-light-subtle shadow-sm">
                            <div class="d-flex justify-content-between align-items-center">

                                <div class="text-center" style="width: 35%;">
                                    <h3 class="mb-0 fw-bold text-primary">@flight.DepartureAirport.IataCode</h3>
                                    <div class="small text-muted fw-semibold mb-2 text-truncate">@flight.DepartureAirport.City</div>
                                    <div class="fs-5 fw-bolder text-dark">@flight.DepartureTime.ToString("HH:mm")</div>
                                    <div class="text-muted" style="font-size: 0.8rem;">@flight.DepartureTime.ToString("dd MMM yyyy")</div>
                                </div>

                                <div class="flex-grow-1 px-2 position-relative text-center">
                                    <div class="text-muted fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">DIRECT</div>
                                    <div class="border-top border-primary border-2 w-100" style="border-style: dashed !important; opacity: 0.3;"></div>
                                    <i class="fa-solid fa-plane text-primary position-absolute start-50 translate-middle-x bg-light px-2" style="top: 14px; transform: translateX(-50%);"></i>
                                </div>

                                <div class="text-center" style="width: 35%;">
                                    <h3 class="mb-0 fw-bold text-primary">@flight.ArrivalAirport.IataCode</h3>
                                    <div class="small text-muted fw-semibold mb-2 text-truncate">@flight.ArrivalAirport.City</div>
                                    <div class="fs-5 fw-bolder text-dark">@flight.ArrivalTime.ToString("HH:mm")</div>
                                    <div class="text-muted" style="font-size: 0.8rem;">@flight.ArrivalTime.ToString("dd MMM yyyy")</div>
                                </div>

                            </div>
                        </div>

                        <a asp-page="/Booking/Create" asp-route-flightId="@flight.ID" class="btn btn-outline-primary w-100 fw-bold py-2 shadow-sm rounded-pill hover-up">
                            Selectează Zborul <i class="fa-solid fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="bg-light mt-5 py-5 border-top border-bottom">
    <div class="container">
        <h3 class="text-center fw-bold mb-5">Personalizează-ți călătoria</h3>
        <div class="row g-4">
            @foreach (var amenity in Model.Amenities)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm amenity-card-modern hover-up">
                        <div class="amenity-image-wrapper">
                            <img src="@(string.IsNullOrEmpty(amenity.ImageUrl) ? "/images/default-service.jpg" : amenity.ImageUrl)"
                                 class="card-img-top" alt="@amenity.Name">
                        </div>

                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="fw-bold text-primary mb-2">@amenity.Name</h5>

                            <p class="text-muted small mb-3 flex-grow-1">
                                @(string.IsNullOrEmpty(amenity.Description) ? "Îmbunătățește-ți experiența de zbor cu serviciile noastre premium." : amenity.Description)
                            </p>

                            <div class="pt-2 border-top">
                                <span class="text-uppercase small fw-bold text-muted d-block">Preț de la</span>
                                <span class="fs-4 fw-bold text-success">@amenity.Price €</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <style>
            .amenity-card-modern {
                border-radius: 15px;
                overflow: hidden;
                transition: all 0.3s ease;
            }

            .amenity-image-wrapper {
                height: 160px;
                overflow: hidden;
            }

                .amenity-image-wrapper img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover; /* Asigură că poza umple spațiul fără să se deformeze */
                    transition: transform 0.5s ease;
                }

            .amenity-card-modern:hover img {
                transform: scale(1.1); /* Efect de zoom la hover pe poză */
            }

            .hover-up:hover {
                transform: translateY(-8px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            }
        </style>
    </div>
</div>