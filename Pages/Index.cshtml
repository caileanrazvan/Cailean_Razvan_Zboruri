@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-light rounded-3 shadow-sm text-center" style="background: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80') no-repeat center center; background-size: cover;">
    <div class="container-fluid py-5" style="background-color: rgba(255, 255, 255, 0.85); border-radius: 15px; display: inline-block; max-width: 700px;">
        <h1 class="display-5 fw-bold text-primary">Bine ai venit la AngelAirlines!</h1>
        <p class="col-md-12 fs-4">Gestionează zboruri, pasageri și rezervări într-un singur loc, simplu și eficient.</p>
        <a class="btn btn-primary btn-lg" href="/Flight/Index" role="button">Vezi Zboruri</a>
    </div>
</div>

<div class="row align-items-md-stretch">
    <div class="col-md-6">
        <div class="h-100 p-5 text-white bg-dark rounded-3">
            <h2><i class="fa-solid fa-user-check"></i> Administrare Pasageri</h2>
            <p>Adaugă pasageri noi, verifică documente și gestionează istoricul clienților tăi.</p>
            <a href="/Passenger/Create" class="btn btn-outline-light" type="button">Adaugă Pasager</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="h-100 p-5 bg-light border rounded-3">
            <h2><i class="fa-solid fa-chart-line"></i> Rapoarte Rezervări</h2>
            <p>Vezi toate rezervările active, locurile ocupate și serviciile extra solicitate.</p>
            <a href="/Booking/Index" class="btn btn-outline-secondary" type="button">Vezi Rezervări</a>
        </div>
    </div>
</div>