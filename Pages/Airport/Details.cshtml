@page
@model Cailean_Razvan_Zboruri.Pages.Airport.DetailsModel
@{
    ViewData["Title"] = "Detalii Aeroport";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0"><i class="fa-solid fa-location-dot"></i> Detalii Aeroport</h4>
            </div>
            <div class="card-body text-center">

                <h1 class="display-4 fw-bold text-primary mb-3">@Model.Airport.IataCode</h1>

                <dl class="row text-start">
                    <dt class="col-sm-4">Oraș</dt>
                    <dd class="col-sm-8">@Model.Airport.City</dd>

                    <dt class="col-sm-4">Țară</dt>
                    <dd class="col-sm-8">@Model.Airport.Country</dd>
                </dl>

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <a asp-page="./Edit" asp-route-id="@Model.Airport.ID" class="btn btn-warning"><i class="fa-solid fa-pen"></i> Editează</a>
                    <a asp-page="./Index" class="btn btn-secondary">Înapoi</a>
                </div>
            </div>
        </div>
    </div>
</div>