@page
@model Cailean_Razvan_Zboruri.Pages.Airport.DeleteModel
@{
    ViewData["Title"] = "Elimină Aeroport";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger text-white p-5">
                    <i class="fa-solid fa-circle-exclamation display-1 mb-3"></i>
                    <h2 class="fw-bold">Atenție!</h2>
                    <p class="mb-0">Urmează să elimini un aeroport din sistem.</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-muted mb-4">Ești sigur că vrei să ștergi acest nod aerian?</h5>

                    <div class="bg-light p-4 rounded-4 mb-4 text-start border border-danger-subtle">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-danger p-3 fs-5 me-3">@Model.Airport.IataCode</span>
                            <div>
                                <h4 class="fw-bold mb-0">@Model.Airport.Name</h4>
                                <span class="text-muted">@Model.Airport.City, @Model.Airport.Country</span>
                            </div>
                        </div>
                        <p class="small text-danger mb-0"><i class="fa-solid fa-triangle-exclamation me-1"></i> Notă: Ștergerea acestui aeroport va afecta toate zborurile asociate.</p>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Airport.ID" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold text-uppercase shadow">
                                <i class="fa-solid fa-trash-can me-2"></i> Confirmă Ștergerea
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg rounded-pill">Renunță</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>