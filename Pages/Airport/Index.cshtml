@page
@model Cailean_Razvan_Zboruri.Pages.Airport.IndexModel
@{
    ViewData["Title"] = "Gestionare Aeroporturi";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-earth-europe text-primary me-2"></i>Noduri Aeriene</h2>
            <p class="text-muted">Gestionează aeroporturile și destinațiile din rețeaua Angel Airlines.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="Create" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold">
                <i class="fa-solid fa-plus-circle me-2"></i>Adaugă Aeroport
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted text-uppercase small">Cod IATA</th>
                        <th class="py-3 text-muted text-uppercase small">Nume Aeroport</th>
                        <th class="py-3 text-muted text-uppercase small">Oraș & Țară</th>
                        <th class="pe-4 py-3 text-end text-muted text-uppercase small">Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Airport)
                    {
                        <tr class="@(!item.IsActive ? "bg-light opacity-75" : "")">
                            <td class="ps-4">
                                <span class="badge @(item.IsActive ? "bg-primary" : "bg-secondary") px-3 py-2 fs-6 shadow-sm">@item.IataCode</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">
                                    @item.Name
                                    @if (!item.IsActive)
                                    {
                                        <span class="badge bg-secondary ms-2"><i class="fa-solid fa-lock me-1"></i>ÎNCHIS</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="fa-solid fa-location-dot @(item.IsActive ? "text-danger" : "text-secondary") me-2"></i>
                                    <span>@item.City, @item.Country</span>
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex justify-content-end align-items-center gap-1">
                                        @if (item.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Cancel" asp-route-id="@item.ID" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-warning text-dark fw-bold rounded-pill px-3 shadow-sm" onclick="return confirm('Dacă închizi acest aeroport, TOATE zborurile și rezervările aferente vor fi anulate automat! Continuăm?');" title="Suspendă Aeroport">
                                                    <i class="fa-solid fa-power-off me-1"></i> Suspendă
                                                </button>
                                            </form>
                                        }
                                        <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Editează">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Șterge Definitiv">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>