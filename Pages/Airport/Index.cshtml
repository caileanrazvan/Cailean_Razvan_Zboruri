@page
@model Cailean_Razvan_Zboruri.Pages.Airport.IndexModel
@{
    ViewData["Title"] = "Gestionare Aeroporturi";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-earth-europe text-primary me-2"></i>Noduri Aeriene</h2>
            <p class="text-muted">Gestionează aeroporturile și destinațiile din rețeaua Angel Airlines.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="Create" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold">
                <i class="fa-solid fa-plus-circle me-2"></i>Adaugă Aeroport
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted text-uppercase small">Cod IATA</th>
                        <th class="py-3 text-muted text-uppercase small">Nume Aeroport</th>
                        <th class="py-3 text-muted text-uppercase small">Oraș & Țară</th>
                        <th class="pe-4 py-3 text-end text-muted text-uppercase small">Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Airport)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-primary px-3 py-2 fs-6 shadow-sm">@item.IataCode</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Name</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="fa-solid fa-location-dot text-danger me-2"></i>
                                    <span>@item.City, @item.Country</span>
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group">
                                        <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-warning rounded-start-pill px-3">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-end-pill px-3">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>