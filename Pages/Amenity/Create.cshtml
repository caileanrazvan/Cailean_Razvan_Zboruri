@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.CreateModel
@{
    ViewData["Title"] = "Adaugă Serviciu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-success text-white p-4">
                    <h3 class="fw-bold mb-0"><i class="fa-solid fa-plus-circle me-2"></i>Adaugă Serviciu Nou</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="Amenity.Name" class="form-label fw-bold text-muted small text-uppercase">Denumire Serviciu</label>
                            <input asp-for="Amenity.Name" class="form-control form-control-lg border-2" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amenity.Price" class="form-label fw-bold text-muted small text-uppercase">Preț (€)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-2 border-end-0"><i class="fa-solid fa-euro-sign text-muted"></i></span>
                                <input asp-for="Amenity.Price" type="text" class="form-control form-control-lg border-2 border-start-0" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amenity.Description" class="form-label fw-bold text-muted small text-uppercase">Descriere</label>
                            <textarea asp-for="Amenity.Description" class="form-control border-2" rows="3" placeholder="Detalii despre acest serviciu..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Imagine Reprezentativă</label>
                            <input type="file" asp-for="UploadedImage" class="form-control border-2" accept="image/*" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-4">
                            <a asp-page="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Anulează</a>
                            <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow rounded-pill text-uppercase">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Salvează
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>