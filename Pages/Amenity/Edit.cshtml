@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.EditModel
@{
    ViewData["Title"] = "Editează Serviciu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-warning text-dark p-4">
                    <h3 class="fw-bold mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>Modifică Serviciu</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Amenity.ID" />

                        <div class="mb-4">
                            <label asp-for="Amenity.Name" class="form-label fw-bold text-muted small text-uppercase">Denumire Serviciu</label>
                            <input asp-for="Amenity.Name" class="form-control form-control-lg border-2" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amenity.Price" class="form-label fw-bold text-muted small text-uppercase">Preț (€)</label>
                            <input asp-for="Amenity.Price" type="text" class="form-control form-control-lg border-2" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amenity.Description" class="form-label fw-bold text-muted small text-uppercase">Descriere</label>
                            <textarea asp-for="Amenity.Description" class="form-control border-2" rows="3"></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Înlocuiește Imaginea (opțional)</label>
                            @if (!string.IsNullOrEmpty(Model.Amenity.ImageUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.Amenity.ImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 100px;" />
                                </div>
                            }
                            <input type="file" asp-for="UploadedImage" class="form-control border-2" accept="image/*" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Înapoi</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold shadow rounded-pill text-uppercase">
                                <i class="fa-solid fa-save me-2"></i> Actualizează
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>