@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.DeleteModel
@{
    ViewData["Title"] = "Șterge Serviciu";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger text-white p-4">
                    <i class="fa-solid fa-triangle-exclamation display-4 mb-2"></i>
                    <h3 class="fw-bold mb-0">Ștergere Serviciu</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-muted mb-4">Ești sigur că vrei să elimini acest serviciu?</h5>

                    <div class="bg-light rounded-4 mb-4 border border-danger-subtle overflow-hidden">
                        @if (!string.IsNullOrEmpty(Model.Amenity.ImageUrl))
                        {
                            <img src="@Model.Amenity.ImageUrl" class="w-100" style="height: 150px; object-fit: cover;" />
                        }
                        <div class="p-4 d-flex justify-content-between align-items-center">
                            <div class="text-start">
                                <h4 class="fw-bold text-dark mb-0">@Model.Amenity.Name</h4>
                            </div>
                            <div class="text-end border-start ps-4">
                                <h4 class="fw-bold text-success mb-0">@Model.Amenity.Price €</h4>
                            </div>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Amenity.ID" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold text-uppercase shadow">
                                <i class="fa-solid fa-trash-can me-2"></i> Confirmă Ștergerea
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary btn-lg rounded-pill">Renunță</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>