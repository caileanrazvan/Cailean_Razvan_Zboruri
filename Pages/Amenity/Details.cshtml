@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.DetailsModel
@{
    ViewData["Title"] = "Detalii Serviciu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <a asp-page="/Index" class="btn btn-outline-secondary rounded-pill mb-4">
                <i class="fa-solid fa-arrow-left me-2"></i>Înapoi la Servicii
            </a>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">

                    <div class="col-md-5 bg-light position-relative" style="min-height: 300px;">
                        @if (!string.IsNullOrEmpty(Model.Amenity.ImageUrl))
                        {
                            <img src="@Model.Amenity.ImageUrl" class="w-100 h-100 position-absolute" style="object-fit: cover; top: 0; left: 0;" alt="@Model.Amenity.Name">
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted position-absolute" style="top: 0; left: 0;">
                                <div class="text-center">
                                    <i class="fa-solid fa-image display-1 opacity-25 mb-3 d-block"></i>
                                    <span>Fără imagine</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="col-md-7">
                        <div class="card-body p-4 p-md-5 d-flex flex-column h-100">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h2 class="fw-bold text-dark mb-0">@Model.Amenity.Name</h2>
                                <span class="badge bg-success fs-4 px-3 py-2 rounded-pill shadow-sm">@Model.Amenity.Price €</span>
                            </div>

                            <hr class="border-secondary opacity-25">

                            <h6 class="text-uppercase text-muted fw-bold small mb-3"><i class="fa-solid fa-circle-info me-2"></i>Descriere Serviciu</h6>
                            <p class="text-dark fs-6" style="line-height: 1.8;">
                                @(string.IsNullOrEmpty(Model.Amenity.Description) ? "Nu există detalii suplimentare pentru acest serviciu în acest moment." : Model.Amenity.Description)
                            </p>

                            <div class="mt-auto pt-4 d-flex gap-2">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-page="./Edit" asp-route-id="@Model.Amenity.ID" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">
                                        <i class="fa-solid fa-pen me-2"></i>Editează
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@Model.Amenity.ID" class="btn btn-outline-danger rounded-pill px-4 fw-bold">
                                        <i class="fa-solid fa-trash me-2"></i>Șterge
                                    </a>
                                }
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>