@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.IndexModel
@{
    ViewData["Title"] = "Facilități";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fa-solid fa-bell-concierge text-primary"></i> Facilități Extra</h1>
    <a asp-page="Create" class="btn btn-success shadow-sm"><i class="fa-solid fa-plus"></i> Adaugă</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="bg-light text-uppercase small fw-bold">
                <tr>
                    <th>Denumire Serviciu</th>
                    <th>Preț</th>
                    <th class="text-end" style="min-width: 150px;">Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Amenity)
                {
                    <tr>
                        <td class="fw-bold">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            <span class="badge bg-info text-dark fs-6">
                                @Html.DisplayFor(modelItem => item.Price) €
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a asp-page="./Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info"><i class="fa-solid fa-circle-info"></i></a>
                                <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-warning"><i class="fa-solid fa-pen"></i></a>
                                <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>