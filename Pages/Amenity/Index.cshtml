@page
@model Cailean_Razvan_Zboruri.Pages.Amenity.IndexModel
@{
    ViewData["Title"] = "Servicii Extra";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-bell-concierge text-primary me-2"></i>Servicii Extra</h2>
            <p class="text-muted mb-0">Gestionează opțiunile suplimentare disponibile pentru pasageri.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="Create" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold">
                <i class="fa-solid fa-plus-circle me-2"></i>Adaugă Serviciu
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model.Amenity)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 transition-hover position-relative overflow-hidden">

                    <div class="position-absolute top-0 end-0 bg-primary text-white px-3 py-1 rounded-bottom-4 shadow-sm fw-bold" style="margin-right: 15px; z-index: 10;">
                        @item.Price €
                    </div>

                    <div style="height: 180px; overflow: hidden; position: relative;" class="bg-light">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@item.Name">
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                <i class="fa-solid fa-image fs-1 opacity-25"></i>
                            </div>
                        }
                    </div>

                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="fw-bold mb-2">@item.Name</h5>

                        <p class="text-muted small mb-4 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @(string.IsNullOrEmpty(item.Description) ? "Fără descriere disponibilă." : item.Description)
                        </p>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2 justify-content-center border-top pt-3 mt-auto">
                                <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-warning rounded-pill px-3 fw-bold flex-grow-1">
                                    <i class="fa-solid fa-pen me-1"></i> Edit
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold flex-grow-1">
                                    <i class="fa-solid fa-trash me-1"></i> Șterge
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>