@page
@model Cailean_Razvan_Zboruri.Pages.Passenger.DetailsModel
@{
    ViewData["Title"] = "Detalii Pasager";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="fa-solid fa-id-card"></i> Profil Pasager</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nume Complet</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Passenger.FullName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8"><a href="mailto:@Model.Passenger.Email">@Model.Passenger.Email</a></dd>

                    <dt class="col-sm-4">Pașaport</dt>
                    <dd class="col-sm-8 font-monospace">@Model.Passenger.PassportNumber</dd>
                </dl>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-page="./Edit" asp-route-id="@Model.Passenger.ID" class="btn btn-warning"><i class="fa-solid fa-pen"></i> Editează</a>
                    <a asp-page="./Index" class="btn btn-secondary">Înapoi</a>
                </div>
            </div>
        </div>
    </div>
</div>